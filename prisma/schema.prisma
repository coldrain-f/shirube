generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model staging_words {
  id             Int     @id @default(autoincrement())
  term           String
  reading        String?
  meaning        String?
  frequency      Int
  part_of_speech String?
  source         String
  is_processed   Boolean @default(false)
}

model dictionaries {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  // Yomitan metadata
  title       String?
  revision    String?
  sequenced   Boolean? @default(true)
  format      Int?     @default(3)
  author      String?
  url         String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  entries dictionary_entries[]
}

model dictionary_entries {
  id             Int      @id @default(autoincrement())
  term           String
  reading        String
  meaning        String
  part_of_speech String
  pitch_accent   String?
  audio_file     String?
  tags           String?
  dictionary_id  Int?
  dictionary     dictionaries? @relation(fields: [dictionary_id], references: [id], onDelete: SetNull)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([term, reading])
}

model yomitan_pos_reference {
  id            Int      @id @default(autoincrement())
  term          String   // 단어
  reading       String   // 읽는 법 (후리가나)
  pos_tags       String?  // UI 표시용 태그 (예: v5k, n)
  yomitan_rules  String?  // Yomitan 파싱용 핵심 규칙 (Index 3)
  source_dict    String   // 출처 (예: "Jitendex", "Daijisen") - Fallback 확인용

  @@unique([term, reading]) // 복합 유니크 키 (빠른 검색 및 중복 방지)
  @@index([term])           // 단어 단일 검색을 위한 인덱스
}